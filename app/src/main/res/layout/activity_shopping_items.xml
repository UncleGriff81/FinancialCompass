<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- TopAppBar с двумя значками справа -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/purple_500"
        app:title="Список покупок"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="?attr/homeAsUpIndicator">

        <!-- Значок "Поделиться" (просто значок, без фона) -->
        <ImageButton
            android:id="@+id/btn_share"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:src="@android:drawable/ic_menu_share"
            android:background="@android:color/transparent"
            android:tint="@android:color/white"
            android:contentDescription="Поделиться" />

        <!-- Круглая кнопка с зелёной галочкой -->
        <ImageButton
            android:id="@+id/btn_complete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_check_green"
            android:background="@drawable/oval_button_background"
            android:tint="@android:color/white"
            android:scaleType="center"
            android:contentDescription="Завершить покупку" />

    </com.google.android.material.appbar.MaterialToolbar>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp" />

    <TextView
        android:id="@+id/tv_total"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="Итого: 0.00 ₽"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#E0E0E0" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <EditText
            android:id="@+id/et_item_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:hint="Название товара"
            android:padding="8dp" />

        <EditText
            android:id="@+id/et_quantity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Кол-во"
            android:inputType="numberDecimal"
            android:padding="8dp" />

        <EditText
            android:id="@+id/et_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Цена"
            android:inputType="numberDecimal"
            android:padding="8dp" />

        <Button
            android:id="@+id/btn_add_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="➕" />

    </LinearLayout>

</LinearLayout>