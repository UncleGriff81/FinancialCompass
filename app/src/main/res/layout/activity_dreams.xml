<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Мои мечты"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- Мечта 1 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Мечта №1"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"/>

    <EditText
        android:id="@+id/et_dream1_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Название мечты (например, Новая машина)"
        android:padding="12dp"
        android:layout_marginTop="8dp"/>

    <EditText
        android:id="@+id/et_dream1_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Сумма цели (₽)"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:layout_marginTop="8dp"/>

    <!-- Мечта 2 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Мечта №2"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"/>

    <EditText
        android:id="@+id/et_dream2_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Название мечты"
        android:padding="12dp"
        android:layout_marginTop="8dp"/>

    <EditText
        android:id="@+id/et_dream2_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Сумма цели (₽)"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:layout_marginTop="8dp"/>

    <!-- Мечта 3 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Мечта №3"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"/>

    <EditText
        android:id="@+id/et_dream3_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Название мечты"
        android:padding="12dp"
        android:layout_marginTop="8dp"/>

    <EditText
        android:id="@+id/et_dream3_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Сумма цели (₽)"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btn_save_dreams"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Сохранить мечты"
        android:layout_marginTop="32dp"/>

    <Button
        android:id="@+id/btn_back_to_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="На главный экран"
        android:layout_marginTop="16dp"/>

</LinearLayout>